# --- The 20,000 DKK Index-Beating Experiment — configuration ---
# Copy to .env for local runs, or set these as GitHub repository secrets
# (Settings → Secrets and variables → Actions) for the scheduled workflows.

# The analyst LLM (Anthropic). The bookkeeper never calls this; only the analyst does.
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot — create one with @BotFather, then message your bot once so it can reply to you.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Your personal chat id (message @userinfobot to get it). Proposals and reports go here.
TELEGRAM_CHAT_ID=123456789

# --- Strategy knobs you actually own (section 8 of the design doc) ---
# Account tax wrapper: "depot" (every sale is a realization event) or "ask" (Aktiesparekonto).
TAX_WRAPPER=depot
# Primary benchmark scoreboard: "msci_world" or "sp500".
PRIMARY_BENCHMARK=msci_world

# --- Kill switch ---
# Set to "true" to pause all proposals — the cycle sends "paused" instead of calling the analyst.
KILL_SWITCH=false

# --- Speculative sleeve opt-in (off by default; flipping this is a different experiment) ---
ALLOW_SPECULATIVE=false

# --- Crypto/derivatives/leverage opt-in (off by default; flipping this is a different experiment) ---
ALLOW_EXOTIC=false
