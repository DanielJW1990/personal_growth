# WHOOP OAuth app credentials — create an app at https://developer.whoop.com
WHOOP_CLIENT_ID=your-client-id
WHOOP_CLIENT_SECRET=your-client-secret

# Optional: refresh token for headless use (obtained by running `npm run auth`).
# The token file (.tokens.json) is preferred when available and survives token rotation.
# WHOOP_REFRESH_TOKEN=

# Optional: override where tokens are stored (default: whoop-mcp/.tokens.json)
# WHOOP_TOKEN_FILE=/absolute/path/to/.tokens.json

# Optional: local OAuth callback settings (must match the redirect URI in your WHOOP app)
# WHOOP_AUTH_PORT=8099
# WHOOP_REDIRECT_URI=http://localhost:8099/callback
